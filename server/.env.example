DATABASE_URL="file:./dev.db"
JWT_ACCESS_SECRET="change-this-to-a-random-64-char-string-for-access-tokens-in-prod"
JWT_REFRESH_SECRET="change-this-to-a-different-random-64-char-string-for-refresh-tokens"
PORT=3001
CLIENT_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@yourdomain.com"
